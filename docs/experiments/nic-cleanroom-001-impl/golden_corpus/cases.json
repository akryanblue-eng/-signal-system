{
  "version": "golden_corpus.v1",
  "description": "Fixed snapshots and fixed expected outputs for NIC v1.1 primitives. Any conforming implementation, in any language, must reproduce every `expect` value (or `expect_error` substring) bit-for-bit given the same `op` and `args`.",
  "cases": [
    {
      "id": "canon-001",
      "category": "canonical",
      "op": "canonical_path",
      "args": {
        "raw": "src/foo.py"
      },
      "expect": "7372632f666f6f2e7079"
    },
    {
      "id": "canon-002",
      "category": "canonical",
      "op": "glob_match",
      "args": {
        "pattern": "*.py",
        "path": "foo.py"
      },
      "expect": true
    },
    {
      "id": "canon-003",
      "category": "canonical",
      "op": "canonicalize_url",
      "args": {
        "raw_url": "http://example.com/x"
      },
      "expect": "http://example.com/x"
    },
    {
      "id": "canon-004",
      "category": "canonical",
      "op": "compute_edge_id",
