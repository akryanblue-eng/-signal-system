{
  "version": "edge_extractor.v1",
  "recognizers": {
    "IMPORT_PY_V1": {
      "input_domain": "python_source",
      "match_rule": "ast_import_statement",
      "edge_type": "import"
    },
    "IMPORT_TS_V1": {
      "input_domain": "typescript_source",
      "match_rule": "es_import_statement",
      "edge_type": "import"
    },
    "URL_REFERENCE_V1": {
      "input_domain": "string_literal",
      "match_rule": "url_literal",
      "edge_type": "url_reference"
    },
    "FILE_REFERENCE_V1": {
      "input_domain": "string_literal",
      "match_rule": "path_literal",
      "edge_type": "file_reference"
    }
  }
}
